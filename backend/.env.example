# ============================================================
#  複製這個檔案為 .env，填入你的 Gemini API Key 後使用。
#  取得：https://aistudio.google.com/apikey
#  注意：.env 已被 .gitignore 擋住，不會上傳 GitHub，金鑰只留在本機。
# ============================================================
GEMINI_API_KEY="your_api_key_here"

# 翻譯模型：建議 flash-lite（免費 RPM 15、速度最快）
GEMINI_MODEL=gemini-2.5-flash-lite
# 翻譯並行 worker 數（免費版建議 2，付費版可拉到 4~6）
TRANSLATOR_WORKERS=2

# ============================================================
#  Whisper —— 依機器二選一
# ============================================================

# ---- runtime 機（GTX 1650 等 NVIDIA 顯卡）：用這三行 ----
WHISPER_MODEL=medium
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8_float16

# ---- 開發機（沒有顯卡）：改用這三行（把上面三行註解掉）----
# WHISPER_MODEL=medium
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8

# 語言模式：
#   auto（演唱會用這個）→ 自動判語言並路由：中文送 Gemini 翻 4 國；
#                          泰/越/印/菲 直接顯示到對應格（翻譯員直顯，跳過 Gemini）
#   zh / vi / ...        → 強制鎖定單一語言（純單語主持人、確定沒有翻譯員時）
WHISPER_LANGUAGE=auto

# auto 模式專用：用一顆輕量模型專門判語言，讓主模型 encoder 只跑一次，
# 在弱 GPU（如 1650）上可砍掉約一半 STT 延遲。tiny 即可；想再準一點可改 base。
# 設成空字串則關閉，退回主模型自偵測（較慢）。
LANG_DETECT_MODEL=tiny

# auto 模式：判語言信心低於此值，就不走「翻譯員直顯」改送 Gemini（保守安全閘）
LANG_CONFIDENCE_MIN=0.7

# CPU 多執行緒：0 = 用所有核心（GPU 模式影響不大）
WHISPER_CPU_THREADS=0
# 並行處理段數，設 1 即可
WHISPER_NUM_WORKERS=1

# WebSocket 服務埠號
PORT=8000
