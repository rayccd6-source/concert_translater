# 複製這個檔案為 .env，並填入你的 Gemini API Key
# 取得方式：https://aistudio.google.com/apikey
GEMINI_API_KEY="your_api_key_here"

# Whisper 模型選擇：
# CPU 場景（沒有 NVIDIA 顯卡）：
#   medium          推薦：CPU 上實際最平衡，RTF ~1.5x（會略慢於 realtime）
#   small           最快但中文短句準度差，會胡言亂語
# GPU 場景（有 NVIDIA 顯卡 + WHISPER_DEVICE=cuda）：
#   large-v3-turbo  推薦：精度近 large、GPU 上跑很快
#   large-v3        最佳精度但稍慢
# 注意：turbo / large-v3 在 CPU 上比 medium 還慢（encoder 跟 large 一樣大）
WHISPER_MODEL=medium

# CPU 多執行緒：0 = 用所有核心；預設只用 4 核
# 8~16 核機器設 0 等於免費加速 2~4x
WHISPER_CPU_THREADS=0

# 並行處理段數，CPU 設 1 即可（多了反而搶資源）
WHISPER_NUM_WORKERS=1

# 強制指定語言：zh（中文）/ vi（越南文）/ auto（自動偵測）
# 演唱會強烈建議鎖定為主持人實際使用的語言，避免短句被誤判成韓文/日文等
# 一場演唱會若只有中文主持人 → zh
# 一場演唱會若是越南文主持人 → vi
# 中越夾雜才用 auto（準確度會略降）
WHISPER_LANGUAGE=zh

# Whisper 在 CPU 上跑，或有 NVIDIA GPU 可以填 cuda
WHISPER_DEVICE=cpu

# Whisper 計算精度：cpu 用 int8，gpu 用 float16
WHISPER_COMPUTE_TYPE=int8

# 翻譯模型：建議用 flash-lite（免費 RPM 限制較寬、速度更快）
# - gemini-2.5-flash-lite：演唱會推薦，免費 RPM 15、速度最快
# - gemini-2.5-flash：較準但免費 RPM 只有 10，3 worker 容易撞額度
GEMINI_MODEL=gemini-2.5-flash-lite

# 翻譯並行 worker 數（免費版建議 2，付費版可拉到 4~6）
TRANSLATOR_WORKERS=2

# WebSocket 服務埠號
PORT=8000
