# 複製這個檔案為 .env，並填入你的 Gemini API Key
# 取得方式：https://aistudio.google.com/apikey
GEMINI_API_KEY="AIzaSyDGUwT0_TgON-D1wIA3sPUOHIVO7r7Xcj4"

# Whisper 模型大小：tiny / base / small / medium / large-v3
# 建議 small（速度與準確度平衡）或 medium（更準但較慢）
WHISPER_MODEL=medium
# Whisper 在 CPU 上跑，或有 NVIDIA GPU 可以填 cuda
WHISPER_DEVICE=cpu

# Whisper 計算精度：cpu 用 int8，gpu 用 float16
WHISPER_COMPUTE_TYPE=int8

# 翻譯模型（gemini-2.5-flash 速度與成本最平衡）
GEMINI_MODEL=gemini-2.5-flash-lite

# WebSocket 服務埠號
PORT=8000
